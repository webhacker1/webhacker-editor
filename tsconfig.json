{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "baseUrl": ".",
        "paths": {
            "@/*": ["./*"]
        },
        "lib": ["ES2020", "DOM", "DOM.Iterable"],
        "strict": false,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "noEmit": true
    },
    "include": [
        "index.ts",
        "constants/**/*.ts",
        "core/**/*.ts",
        "features/**/*.ts",
        "sanitize/**/*.ts",
        "ui/**/*.ts",
        "types/**/*.d.ts"
    ]
}
